# Supabase — get these from supabase.com → your project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox — get from mapbox.com → Account → Tokens
VITE_MAPBOX_TOKEN=

# Stripe — get from dashboard.stripe.com (fill in Phase 9)
VITE_STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
STRIPE_PREMIUM_ANNUAL_PRICE_ID=
STRIPE_PATRON_MONTHLY_PRICE_ID=

# Resend — get from resend.com (fill in Phase 7)
RESEND_API_KEY=

# PostHog analytics — get from posthog.com (fill in Phase 9)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# App
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Parish App
